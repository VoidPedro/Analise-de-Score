<p style="color: green"><%= notice %></p>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
  <h1 style="margin: 0;">Aplicantes</h1>
  <%= link_to "Novo Aplicante", new_applicant_path, 
      style: "padding: 10px 20px; background-color: #0066cc; color: white; 
              text-decoration: none; border-radius: 4px; font-weight: bold;" %>
</div>

<% if @applicants.any? %>
  <div id="applicants" style="display: grid; gap: 20px;">
    <% @applicants.each do |applicant| %>
      <%= render applicant %>
    <% end %>
  </div>
<% else %>
  <div style="background-color: #f0f0f0; padding: 40px; text-align: center; border-radius: 8px;">
    <p style="font-size: 16px; color: #666;">Nenhum solicitante cadastrado ainda.</p>
    <%= link_to "Cadastre um novo solicitante", new_applicant_path, 
        style: "color: #0066cc; text-decoration: none; font-weight: bold;" %>
  </div>
<% end %>
