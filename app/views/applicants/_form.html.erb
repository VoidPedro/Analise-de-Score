<%= form_with(model: applicant, local: true) do |form| %>
  <% if applicant.errors.any? %>
    <div style="color: red; margin-bottom: 20px;">
      <h3 style="margin: 0 0 10px 0;"><%= pluralize(applicant.errors.count, "erro") %> encontrado:</h3>
      <ul style="margin: 0; padding-left: 20px;">
        <% applicant.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 20px;">
    <%= form.label :name, "Nome", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= form.text_field :name,
        style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; box-sizing: border-box;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= form.label :cpf, "CPF (11 dígitos)", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= form.text_field :cpf,
        style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; box-sizing: border-box;" %>
    <p style="margin: 5px 0 0 0; color: #666; font-size: 12px;">
      ℹ️ CPF sem formatação (apenas números)
    </p>
  </div>

  <div style="margin-bottom: 20px;">
    <%= form.label :income, "Renda Mensal (R$)", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= form.number_field :income, step: :any,
        style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; box-sizing: border-box;" %>
  </div>

  <div>
    <%= form.submit "Salvar",
        style: "padding: 10px 20px; background-color: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; width: 100%;" %>
  </div>
<% end %>
