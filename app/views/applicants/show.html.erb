<p style="color: green; margin: 15px 0; padding: 10px; background-color: #e8f5e9; border-radius: 4px; border-left: 4px solid #4CAF50;"><%= notice %></p>

<div style="max-width: 700px; margin: 30px auto;">
  <div style="border: 2px solid #ddd; padding: 20px; border-radius: 8px; background-color: #f9f9f9; margin-bottom: 20px;">
    <h2 style="margin: 0 0 15px 0; color: #333;"><%= @applicant.name %></h2>
    
    <div style="margin-bottom: 15px;">
      <p style="margin: 5px 0; color: #666;">
        <strong>CPF:</strong> <%= @applicant.cpf %>
      </p>
      <p style="margin: 5px 0; color: #666;">
        <strong>Renda:</strong> R$ <%= number_with_precision(@applicant.income, precision: 2, delimiter: ',', separator: '.') %>
      </p>
      <p style="margin: 5px 0; color: #666;">
        <strong>Cadastrado em:</strong> <%= l(@applicant.created_at, format: :short) %>
      </p>
    </div>
  </div>

  <div style="display: flex; gap: 10px;">
    <%= link_to "Editar", edit_applicant_path(@applicant),
        style: "flex: 1; padding: 10px 20px; background-color: #0066cc; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-weight: bold;" %>
    <%= link_to "Voltar", applicants_path,
        style: "flex: 1; padding: 10px 20px; background-color: #666; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-weight: bold;" %>
    <%= button_to "Deletar", @applicant, method: :delete,
        style: "flex: 1; padding: 10px 20px; background-color: #cc0000; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;" %>
  </div>
</div>
